{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crumb",
  "version": "0.1.0",
  "identifier": "com.foxfire.crumb",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "popover",
        "title": "Crumb",
        "url": "index.html",
        "width": 380,
        "height": 520,
        "minWidth": 380,
        "minHeight": 300,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "fullscreen": false,
        "shadow": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "active"
        }
      },
      {
        "label": "settings",
        "title": "Crumb Settings",
        "url": "index.html",
        "width": 560,
        "height": 640,
        "minWidth": 480,
        "minHeight": 520,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "focus": false,
        "fullscreen": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  },
  "plugins": {}
}
